Subroutine neglect_ions

! find ions which can be neglected

  Use :: nlte_type
  Use :: fastwind_params, Only: fracmin, natom

  Use :: nlte_app, Only: abund, fjk, jatom, jmax, calcion

  Implicit None

  Integer (i4b) :: k, j
  Real (dp) :: fjkmax

  calcion = 0

  Do k = 1, natom
    If (jatom(k)==0) Cycle
    Do j = 1, jmax(k)
      fjkmax = maxval(fjk(k,j,:))
      If (abund(k)*fjkmax>fracmin) calcion(k, j) = 1
    End Do
  End Do
  Return
End Subroutine

